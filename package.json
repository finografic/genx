{
  "name": "@finografic/genx",
  "type": "module",
  "version": "4.7.0",
  "description": "Opinionated generator and codemod toolkit for the @finografic ecosystem.",
  "homepage": "https://github.com/finografic/genx",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/finografic/genx.git"
  },
  "bugs": {
    "url": "https://github.com/finografic/genx/issues"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "author": {
    "name": "Justin",
    "email": "justin.blair.rankin@gmail.com"
  },
  "license": "MIT",
  "keywords": [
    "finografic",
    "generator",
    "scaffold",
    "codemod",
    "cli"
  ],
  "bin": {
    "genx": "./dist/index.mjs"
  },
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "module": "./dist/index.mjs",
  "files": [
    "dist",
    "_templates",
    "_templates/**/.npmrc",
    "_templates/**/.gitignore"
  ],
  "exports": {
    ".": "./dist/index.mjs",
    "./package.json": "./package.json"
  },
  "scripts": {
    "---------- DEV_AND_BUILD": "---------------------------------------------",
    "dev": "tsdown --watch",
    "dev.cli": "NODE_ENV=development tsx src/cli.ts --",
    "dev.feature": "tsx --tsconfig tsconfig.scripts.json scripts/new-feature.ts",
    "link": "pnpm build && pnpm link --global",
    "unlink": "pnpm unlink --global",
    "build": "tsdown",
    "·········· TESTING": "···················································",
    "test": "vitest",
    "test.run": "vitest run",
    "test.coverage": "vitest run --coverage",
    "·········· LINTING": "···················································",
    "lint": "eslint .",
    "lint.fix": "eslint . --fix",
    "·········· FORMATTING": "················································",
    "format.check": "oxfmt --check",
    "format.fix": "oxfmt",
    "·········· PUBLISH.GITHUB": "············································",
    "release.github.patch": "pnpm run release.check && pnpm version patch && git push --follow-tags",
    "release.github.minor": "pnpm run release.check && pnpm version minor && git push --follow-tags",
    "release.github.major": "pnpm run release.check && pnpm version major && git push --follow-tags",
    "release.check": "pnpm lint.fix && pnpm typecheck && pnpm check:cli-core-spec && pnpm test.run",
    "release.publish": "pnpm publish --registry https://npm.pkg.github.com",
    "·········· REGISTRIES": "················································",
    "view.registry.github": "pnpm view @finografic/genx --registry=https://npm.pkg.github.com",
    "·········· PACKAGES": "··················································",
    "update.core": "pnpm update @finografic/core --latest",
    "update.eslint-config": "pnpm update @finografic/eslint-config --latest",
    "update.oxfmt-config": "pnpm update @finografic/oxfmt-config --latest && pnpm update oxfmt --latest",
    "update.project-scripts": "pnpm update @finografic/project-scripts --latest",
    "upgrade.deps.all": "pnpm update --latest",
    "·········· DOCS": "······················································",
    "docs.usage": "tsx scripts/generate-readme-usage.ts",
    "·········· UTILS": "·····················································",
    "check:cli-core-spec": "node scripts/check-cli-core-template.mjs",
    "tsc.debug": "tsc --pretty --project tsconfig.json",
    "typecheck": "tsc --project tsconfig.json --noEmit",
    "prepack": "pnpm build",
    "prepare": "simple-git-hooks"
  },
  "dependencies": {
    "@clack/prompts": "1.1.0",
    "@finografic/core": "^0.9.2",
    "@finografic/genx": "link:",
    "clack-tree-select": "^1.0.8",
    "execa": "^9.6.1",
    "fast-glob": "^3.3.3",
    "jsonc-parser": "^3.3.1",
    "picocolors": "^1.1.1",
    "zod": "^4.3.4"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.2.0",
    "@commitlint/config-conventional": "^20.2.0",
    "@eslint/js": "^9.39.2",
    "@finografic/oxfmt-config": "^1.0.3",
    "@stylistic/eslint-plugin": "^5.6.1",
    "@types/node": "24.0.0",
    "@typescript-eslint/eslint-plugin": "^8.51.0",
    "@typescript-eslint/parser": "^8.51.0",
    "eslint": "9.39.2",
    "eslint-plugin-markdownlint": "^0.9.0",
    "globals": "^17.3.0",
    "lint-staged": "^16.2.7",
    "oxfmt": "^0.43.0",
    "simple-git-hooks": "^2.13.1",
    "tsdown": "^0.20.3",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.51.0",
    "vitest": "^4.0.18"
  },
  "packageManager": "pnpm@10.32.1",
  "lint-staged": {
    "*.{ts,tsx,js,jsx,mjs,cjs}": [
      "oxfmt --no-error-on-unmatched-pattern",
      "eslint --fix"
    ],
    "*.md": [
      "oxfmt --no-error-on-unmatched-pattern",
      "eslint --fix"
    ],
    "*.{json,jsonc,yml,yaml,toml}": [
      "oxfmt --no-error-on-unmatched-pattern"
    ]
  },
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ]
  },
  "simple-git-hooks": {
    "pre-commit": "npx lint-staged --allow-empty"
  }
}
