{
  "name": "@finografic/genx",
  "type": "module",
  "version": "5.34.7",
  "description": "Opinionated generator and codemod toolkit for the @finografic ecosystem.",
  "homepage": "https://github.com/finografic/genx",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/finografic/genx.git"
  },
  "bugs": {
    "url": "https://github.com/finografic/genx/issues"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "author": {
    "name": "Justin",
    "email": "justin.blair.rankin@gmail.com"
  },
  "license": "MIT",
  "keywords": [
    "finografic",
    "generator",
    "scaffold",
    "codemod",
    "cli"
  ],
  "bin": {
    "genx": "./dist/index.mjs"
  },
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "module": "./dist/index.mjs",
  "files": [
    "dist",
    "_templates",
    "_templates/**/.npmrc",
    "_templates/**/.gitignore"
  ],
  "exports": {
    ".": "./dist/index.mjs",
    "./package.json": "./package.json"
  },
  "scripts": {
    "---------- DEV_AND_BUILD": "---------------------------------------------",
    "dev": "tsdown --watch",
    "dev:cli": "NODE_ENV=development tsx src/cli.ts --",
    "dev:feature": "tsx --tsconfig tsconfig.scripts.json .github/skills/generate-new-genx-feature/new-feature.ts",
    "link": "pnpm build && pnpm link --global",
    "unlink": "pnpm unlink --global",
    "build": "tsdown",
    "·········· TESTING": "···················································",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "smoke:ai-memory": "tsx scripts/smoke-ai-memory.ts",
    "·········· LINTING": "···················································",
    "lint": "oxlint -c oxlint.config.ts",
    "lint:fix": "oxlint -c oxlint.config.ts --fix",
    "lint:ci": "oxlint -c oxlint.config.ts --quiet",
    "lint:md": "md-lint",
    "lint:md:fix": "md-lint --fix",
    "·········· FORMATTING": "················································",
    "format:check": "oxfmt --check",
    "format:fix": "oxfmt",
    "·········· PUBLISH:GITHUB": "············································",
    "release:github:patch": "pnpm run release:check && pnpm version patch && git push --follow-tags",
    "release:github:minor": "pnpm run release:check && pnpm version minor && git push --follow-tags",
    "release:github:major": "pnpm run release:check && pnpm version major && git push --follow-tags",
    "release:check": "pnpm lint:fix && pnpm format:check && pnpm typecheck && pnpm check:cli-core-spec && pnpm test:run",
    "release:publish": "pnpm publish --registry https://npm.pkg.github.com",
    "·········· REGISTRIES": "················································",
    "view:registry:github": "pnpm view @finografic/genx --registry=https://npm.pkg.github.com",
    "·········· PACKAGES": "··················································",
    "update:deps-policy": "pnpm update @finografic/deps-policy --latest",
    "update:cli-kit": "pnpm update @finografic/cli-kit --latest",
    "update:oxc-config": "pnpm update @finografic/oxc-config --latest && pnpm update oxfmt --latest && pnpm update oxlint --latest",
    "update:project-scripts": "pnpm update @finografic/project-scripts --latest",
    "update:deps:all": "pnpm update --latest",
    "·········· DOCS": "······················································",
    "docs:usage": "tsx scripts/generate-readme-usage.ts",
    "·········· UTILS": "·····················································",
    "clean": "pnpm --package=@finografic/project-scripts dlx purge-builds --recursive --detach",
    "list:managed-repos": "tsx --tsconfig tsconfig.scripts.json scripts/list-managed-repos.ts",
    "check:cli-core-spec": "node scripts/check-cli-core-template.mjs",
    "tsc:debug": "tsc --pretty --project tsconfig.json",
    "typecheck": "tsc --project tsconfig.json --noEmit",
    "prepack": "pnpm build",
    "prepare": "husky"
  },
  "dependencies": {
    "@clack/prompts": "1.1.0",
    "@finografic/cli-kit": "^1.4.0",
    "@finografic/core": "^0.9.2",
    "@finografic/deps-policy": "^0.26.0",
    "clack-tree-select": "^1.0.8",
    "diff": "^8.0.4",
    "execa": "^9.6.1",
    "fast-glob": "^3.3.3",
    "jsonc-parser": "^3.3.1",
    "picocolors": "^1.1.1",
    "semver": "^7.7.4",
    "zod": "^4.3.4"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "@finografic/md-lint": "^0.15.3",
    "@finografic/oxc-config": "^2.6.6",
    "@finografic/project-scripts": "^1.3.3",
    "@types/node": "24.12.0",
    "@types/semver": "^7.7.1",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.6",
    "oxfmt": "^0.52.0",
    "oxlint": "^1.67.0",
    "oxlint-tsgolint": "^0.23.0",
    "tsdown": "^0.22.1",
    "tsx": "^4.21.0",
    "typescript": "6.0.2",
    "vitest": "^4.1.7"
  },
  "packageManager": "pnpm@10.32.1",
  "lint-staged": {
    "*.{ts,tsx,js,jsx,mjs,cjs}": [
      "oxfmt --no-error-on-unmatched-pattern",
      "oxlint -c oxlint.config.ts --fix --no-error-on-unmatched-pattern --ignore-pattern '_templates/package-types/**'"
    ],
    "*.md": [
      "oxfmt --no-error-on-unmatched-pattern",
      "md-lint --fix"
    ],
    "*.{json,jsonc,yml,yaml,toml}": [
      "oxfmt --no-error-on-unmatched-pattern"
    ]
  },
  "engines": {
    "node": ">=24.3.0"
  }
}
