# If README.md was changed by codegen, create a follow-up commit that contains only README.md.
# This runs after the user's commit so tests can proceed without failures.
#
# Guard against infinite loops by skipping when the current commit is already the docs auto-commit.

CURRENT_MSG="$(git log -1 --format=%B HEAD 2>/dev/null || true)"

AUTO_COMMIT_PREFIX="docs: readme.md update"
case "$CURRENT_MSG" in
"$AUTO_COMMIT_PREFIX"*) exit 0 ;;
esac

if [ ! -f README.md ]; then exit 0; fi

# Track existing diffs so we don't interfere with unrelated local edits.
BEFORE_NON_README="$(git diff --name-only | rg -v '^README\.md$' || true)"
BEFORE_HAS_README="$(git diff --name-only | rg -q '^README\.md$' && echo yes || echo no)"

# If README.md was already modified before we ran codegen, skip to avoid doubling a user/other tool change.
if [ "$BEFORE_HAS_README" = "yes" ]; then
	exit 0
fi

# Run generator. It should only touch README.md.
pnpm docs:usage >/dev/null 2>&1 || exit 0

# If README.md didn't change, nothing to do.
AFTER_HAS_README="$(git diff --name-only | rg -q '^README\.md$' && echo yes || echo no)"
if [ "$AFTER_HAS_README" != "yes" ]; then exit 0; fi

# Ensure we didn't accidentally touch other files.
AFTER_NON_README="$(git diff --name-only | rg -v '^README\.md$' || true)"
if [ "$AFTER_NON_README" != "$BEFORE_NON_README" ]; then
	# Unexpected behavior; skip auto-commit so we don't create surprise commits.
	exit 0
fi

# Show diff for user visibility (same idea as feature overwrites).
printf "\n\033[33m----- docs: readme.md update (generated changes) -----\033[0m\n"
git --no-pager diff -- README.md
printf "\n\033[33m------------------------------------------------------\033[0m\n"

git add README.md
git commit -m "docs: readme.md update" --no-verify
